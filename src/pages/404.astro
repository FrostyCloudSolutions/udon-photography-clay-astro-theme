---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found" description="This page doesn't exist.">
  <article class="post-content no-image">
    <header class="post-content-header">
      <h1 class="post-content-title">Page not found</h1>
    </header>
    <p class="post-content-excerpt">
      This page doesn't exist — it may have moved when the site was updated.
    </p>
    <div class="post-content-body" style="text-align: center;">
      <p><a href="/">Back to the homepage</a> · <a href="/portfolio">Browse the portfolio</a></p>
    </div>
  </article>
</Layout>
