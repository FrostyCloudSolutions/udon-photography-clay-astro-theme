---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getPage, getHomeTiles, cardImage } from '../lib/sanity';

const home = await getPage('page-home');
const title = home?.title ?? 'Udon Studio';
const description = home?.description ?? undefined;

// The three tiles (About / Portfolio / Inquire) are a design constant;
// each shows that page's own image and title from Sanity.
const tiles = await getHomeTiles();
---

<Layout title={title} description={description}>
    <header class="post-content-header">
    <h1 class="post-content-title">{title}</h1>
        {description && <p class="post-content-excerpt">{description}</p>}
    </header>
    <div class="post-feed grid-3">
        {tiles.map((tile, index) => (
            <PostCard
                count={index + 1}
                title={tile.title}
                thumbnail={tile.image ? cardImage(tile.image) : undefined}
                slug={tile.slug}
            />
        ))}
    </div>
</Layout>
