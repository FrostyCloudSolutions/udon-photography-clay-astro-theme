---
import WorkTemplate from '../../templates/Work.astro';
import { PORTFOLIO_CATEGORIES } from '../../lib/categories';
import { getPage, getPostsFull } from '../../lib/sanity';

export async function getStaticPaths() {
  const section = await getPage('page-portfolio');
  const posts = await getPostsFull(); // newest first

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      // Left arrow walks to the newer post, right arrow to the older
      // one (same convention as the previous implementation).
      next: index === 0 ? null : posts[index - 1],
      prev: index === posts.length - 1 ? null : posts[index + 1],
      sectionTitle: section?.title ?? 'Portfolio',
      sectionDescription: section?.description ?? '',
    },
  }));
}

const { post, next, prev, sectionTitle, sectionDescription } = Astro.props;
---

<WorkTemplate
  post={post}
  next={next}
  prev={prev}
  baseSlug="portfolio"
  categories={PORTFOLIO_CATEGORIES}
  sectionTitle={sectionTitle}
  sectionDescription={sectionDescription}
/>
