---
import { getCollection } from 'astro:content';
import WorkTemplate from '../../templates/Work.astro';
import { JOURNAL_CATEGORIES } from '../../lib/categories';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  const sectionEntry = pages.find((p) => p.slug === 'journal');
  const sectionTitle = sectionEntry?.data.title ?? 'Journal';
  const sectionDescription = sectionEntry?.data.description ?? '';

  const entries = await getCollection('news');
  const sortedEntries = entries.sort((a, b) => {
    return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
  });

  return sortedEntries.map((entry, index) => {
    const newer = index === 0 ? null : sortedEntries[index - 1];
    const older = index === sortedEntries.length - 1 ? null : sortedEntries[index + 1];

    return {
      params: { slug: entry.slug },
      props: {
        entry,
        next: newer,
        prev: older,
        sectionTitle,
        sectionDescription,
      },
    };
  });
}

const { entry, next, prev, sectionTitle, sectionDescription } = Astro.props;
---

<WorkTemplate
  entry={entry}
  next={next}
  prev={prev}
  baseSlug="journal"
  categories={JOURNAL_CATEGORIES}
  sectionTitle={sectionTitle}
  sectionDescription={sectionDescription}
/>
