---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
  next?: any;
  prev?: any;
  baseSlug?: string; // e.g. 'work'
  categories?: string[];
  sectionTitle?: string;
  sectionDescription?: string;
}

const { entry, next, prev, baseSlug, categories = [], sectionTitle, sectionDescription } = Astro.props;
const { Content } = await entry.render();

const { title, description, thumbnail, date, category } = entry.data;
const photos = entry.data.photos ?? [];
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<Layout title={title} description={description}>
  <article class={`post-content ${photos.length > 0 || thumbnail ? '' : 'no-image'}`}>
    {sectionTitle && (
      <header class="post-content-header">
        <h1 class="post-content-title">{sectionTitle}</h1>
      </header>
    )}

    {sectionDescription && (
      <p class="post-content-excerpt">{sectionDescription}</p>
    )}

    {categories.length > 0 && (
      <div class="filter-bar" role="group" aria-label={`Browse ${sectionTitle} by category`}>
        <a class="filter-pill" href={`/${baseSlug}`} data-category="all">All</a>
        {categories.map((cat) => (
          <a
            class={`filter-pill ${cat === category ? 'is-active' : ''}`}
            href={`/${baseSlug}?category=${encodeURIComponent(cat)}`}
            data-category={cat}
          >
            {cat}
          </a>
        ))}
      </div>
    )}

    <header class="post-content-header">
    <h1 class="post-content-title">
      {title}
      {formattedDate && <time class="post-content-date" datetime={new Date(date).toISOString()}>{formattedDate}</time>}
    </h1>
    </header>

    {description && (
      <p class="post-content-excerpt">{description}</p>
    )}

    {photos.length > 0 ? (
      <div class="post-gallery" data-gallery>
        {photos.length > 1 && (
          <div class="gallery-strip-row">
            <button class="gallery-arrow gallery-prev" aria-label="Previous photos" hidden>&#8249;</button>
            <div class="gallery-strip">
              {photos.map((photo, i) => (
                <button
                  class={`gallery-thumb ${i === 0 ? 'is-current' : ''}`}
                  data-caption={photo.caption || ''}
                  aria-label={`Show photo ${i + 1} of ${photos.length}`}
                >
                  <img src={photo.image} alt={photo.caption || `${title} — photo ${i + 1}`} loading="lazy" />
                </button>
              ))}
            </div>
            <button class="gallery-arrow gallery-next" aria-label="Next photos" hidden>&#8250;</button>
          </div>
        )}
        <button class="gallery-stage" aria-label="View this photo fullscreen">
          <img
            class="gallery-stage-image"
            src={photos[0].image}
            alt={photos[0].caption || `${title} — photo 1`}
          />
        </button>
        <p class="gallery-stage-caption" hidden={!photos[0].caption}>{photos[0].caption}</p>
      </div>
    ) : thumbnail && (
      <div class="post-content-image">
        <img src={thumbnail} class="kg-image" alt={title} />
      </div>
    )}

    <div class="post-content-body">
      <Content />
    </div>

    <div class="post-link">
      <div>
        {next && (
            <a style="display: flex; align-items: center; color: #131313; font-size: 2rem;" href={`/${baseSlug}/${next.slug}`}>
               <span>&larr; {next.data.title}</span>
            </a>
        )}
      </div>
      <div>
        {prev && (
            <a style="display: flex; align-items: center; color: #131313; font-size: 2rem;" href={`/${baseSlug}/${prev.slug}`}>
               <span>{prev.data.title} &rarr;</span>
            </a>
        )}
      </div>
    </div>

  </article>

  {photos.length > 0 && (
    <div class="lightbox" id="gallery-lightbox" hidden>
      <button class="lightbox-control lightbox-close" aria-label="Close fullscreen view">&times;</button>
      <button class="lightbox-control lightbox-arrow lightbox-prev" aria-label="Previous photo">&#8249;</button>
      <figure class="lightbox-figure">
        <img class="lightbox-image" src="" alt="" />
        <div class="lightbox-caption" hidden></div>
        <figcaption class="lightbox-counter"></figcaption>
      </figure>
      <button class="lightbox-control lightbox-arrow lightbox-next" aria-label="Next photo">&#8250;</button>
    </div>
  )}
</Layout>

<style>
  /* Filmstrip gallery. The !important flags counter the global button
     reset in buttons.css (black background, white text, inset shadow). */
  .post-gallery {
    margin: 4vw 0;
  }

  .gallery-stage {
    display: block;
    width: 100%;
    height: auto;
    padding: 0;
    border: none;
    border-radius: 0;
    background-color: transparent !important;
    box-shadow: none !important;
    line-height: 0;
    cursor: zoom-in;
  }
  .gallery-stage-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }

  .gallery-stage-caption {
    margin: 0.8rem 0 0;
    font-family: var(--font-sans-serif);
    font-size: 1.5rem;
    text-align: center;
    color: var(--color-base);
    opacity: 0.7;
  }
  .gallery-stage-caption[hidden] {
    display: none;
  }

  .gallery-strip-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
  }

  .gallery-strip {
    display: flex;
    flex: 1;
    gap: 0.8rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .gallery-strip::-webkit-scrollbar {
    display: none;
  }

  .gallery-thumb {
    flex: 0 0 calc((100% - 4 * 0.8rem) / 5);
    aspect-ratio: 1 / 1;
    scroll-snap-align: start;
    height: auto;
    line-height: 0;
    padding: 0;
    border: none;
    border-radius: 0;
    background-color: transparent !important;
    box-shadow: none !important;
    cursor: pointer;
  }
  .gallery-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .gallery-thumb:hover img,
  .gallery-thumb.is-current img {
    opacity: 1;
  }
  .gallery-thumb.is-current {
    outline: 2px solid var(--color-base);
    outline-offset: -2px;
  }
  @media (max-width: 700px) {
    .gallery-thumb {
      flex-basis: calc((100% - 2 * 0.8rem) / 3);
    }
  }

  .gallery-arrow {
    height: auto;
    padding: 0 0.4rem;
    border: none;
    border-radius: 0;
    background-color: transparent !important;
    color: var(--color-base) !important;
    box-shadow: none !important;
    font-size: 3.6rem;
    line-height: 1;
    opacity: 0.6;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .gallery-arrow:hover:not(:disabled) {
    opacity: 1;
  }
  .gallery-arrow:disabled {
    opacity: 0.15;
    cursor: default;
  }

  /* Fullscreen lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.93);
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox-figure {
    margin: 0;
    text-align: center;
  }
  .lightbox-image {
    display: block;
    max-width: 86vw;
    max-height: 84vh;
    object-fit: contain;
  }
  .lightbox-caption {
    margin-top: 1.2rem;
    color: #fff;
    opacity: 0.85;
    font-family: var(--font-sans-serif);
    font-size: 1.6rem;
  }
  .lightbox-caption[hidden] {
    display: none;
  }
  .lightbox-counter {
    margin-top: 1.2rem;
    color: #fff;
    opacity: 0.7;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    letter-spacing: 1px;
  }
  .lightbox-control {
    height: auto;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0;
    background-color: transparent !important;
    color: #fff !important;
    box-shadow: none !important;
    line-height: 1;
    opacity: 0.7;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .lightbox-control:hover {
    opacity: 1;
  }
  .lightbox-close {
    position: absolute;
    top: 1.2rem;
    right: 1.6rem;
    font-size: 4rem;
  }
  .lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 5rem;
  }
  .lightbox-prev {
    left: 1.2rem;
  }
  .lightbox-next {
    right: 1.2rem;
  }

  .post-content-date {
    display: inline-block;
    margin-left: 1rem;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    font-weight: var(--font-normal);
    color: var(--color-base);
    opacity: 0.5;
    vertical-align: middle;
  }
  @media (max-width: 700px) {
    .post-content-date {
      display: block;
      margin-left: 0;
      margin-top: 0.5rem;
    }
  }
</style>

<script>
  function initGallery() {
    const gallery = document.querySelector<HTMLElement>('[data-gallery]');
    const lightbox = document.getElementById('gallery-lightbox');
    if (!gallery || !lightbox || gallery.dataset.enhanced === '1') return;
    gallery.dataset.enhanced = '1';

    const stage = gallery.querySelector<HTMLButtonElement>('.gallery-stage')!;
    const stageImage = stage.querySelector<HTMLImageElement>('.gallery-stage-image')!;
    const stageCaption = gallery.querySelector<HTMLElement>('.gallery-stage-caption');
    const strip = gallery.querySelector<HTMLElement>('.gallery-strip');
    const thumbs = [...gallery.querySelectorAll<HTMLButtonElement>('.gallery-thumb')];
    const images = thumbs.length > 0 ? thumbs.map((t) => t.querySelector('img')!) : [stageImage];
    const captions =
      thumbs.length > 0 ? thumbs.map((t) => t.dataset.caption || '') : [stageCaption?.textContent?.trim() || ''];
    let current = 0;

    // Clicking a thumbnail swaps that photo onto the stage.
    const setCurrent = (index: number) => {
      current = (index + images.length) % images.length;
      stageImage.src = images[current].getAttribute('src') || '';
      stageImage.alt = images[current].alt;
      if (stageCaption) {
        stageCaption.textContent = captions[current];
        stageCaption.hidden = !captions[current];
      }
      thumbs.forEach((t, i) => t.classList.toggle('is-current', i === current));
    };
    thumbs.forEach((thumb, index) => thumb.addEventListener('click', () => setCurrent(index)));

    // Filmstrip paging: arrows appear only when the strip overflows, and
    // scroll it one full "page" (the visible width) at a time.
    if (strip) {
      const prevBtn = gallery.querySelector<HTMLButtonElement>('.gallery-prev')!;
      const nextBtn = gallery.querySelector<HTMLButtonElement>('.gallery-next')!;
      const updateArrows = () => {
        const overflows = strip.scrollWidth > strip.clientWidth + 1;
        prevBtn.hidden = nextBtn.hidden = !overflows;
        if (overflows) {
          prevBtn.disabled = strip.scrollLeft <= 1;
          nextBtn.disabled = strip.scrollLeft + strip.clientWidth >= strip.scrollWidth - 1;
        }
      };
      // Page by whole thumbnails so the target lands exactly on a snap
      // point (smooth scrolling to a non-aligned offset fights the
      // mandatory scroll snap in some browsers).
      const pageBy = (direction: number) => {
        const unit = thumbs[0].offsetWidth + parseFloat(getComputedStyle(strip).gap || '0');
        const perPage = Math.max(1, Math.floor(strip.clientWidth / unit));
        const max = strip.scrollWidth - strip.clientWidth;
        const target = Math.max(0, Math.min(strip.scrollLeft + direction * perPage * unit, max));
        strip.scrollTo({ left: target, behavior: 'smooth' });
      };
      prevBtn.addEventListener('click', () => pageBy(-1));
      nextBtn.addEventListener('click', () => pageBy(1));
      strip.addEventListener('scroll', updateArrows, { passive: true });
      window.addEventListener('resize', updateArrows);
      updateArrows();
    }

    // Fullscreen lightbox, opened by clicking the stage. Navigating in
    // the lightbox keeps the stage in sync.
    const lightboxImage = lightbox.querySelector<HTMLImageElement>('.lightbox-image')!;
    const lightboxCaption = lightbox.querySelector<HTMLElement>('.lightbox-caption')!;
    const counter = lightbox.querySelector<HTMLElement>('.lightbox-counter')!;

    const show = (index: number) => {
      setCurrent(index);
      lightboxImage.src = images[current].getAttribute('src') || '';
      lightboxImage.alt = images[current].alt;
      lightboxCaption.textContent = captions[current];
      lightboxCaption.hidden = !captions[current];
      counter.textContent = `${current + 1} / ${images.length}`;
    };
    const open = (index: number) => {
      show(index);
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lightbox.hidden = true;
      document.body.style.overflow = '';
    };

    stage.addEventListener('click', () => open(current));
    lightbox.querySelector('.lightbox-close')!.addEventListener('click', close);
    lightbox.querySelector('.lightbox-prev')!.addEventListener('click', () => show(current - 1));
    lightbox.querySelector('.lightbox-next')!.addEventListener('click', () => show(current + 1));
    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) close();
    });
    document.addEventListener('keydown', (event) => {
      if (lightbox.hidden) return;
      if (event.key === 'Escape') close();
      if (event.key === 'ArrowLeft') show(current - 1);
      if (event.key === 'ArrowRight') show(current + 1);
    });
  }

  initGallery();
  document.addEventListener('astro:page-load', initGallery);
</script>
