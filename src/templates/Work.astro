---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'> | CollectionEntry<'news'>;
  next?: any;
  prev?: any;
  baseSlug?: string; // e.g. 'work'
  categories?: string[];
}

const { entry, next, prev, baseSlug, categories = [] } = Astro.props;
const { Content } = await entry.render();

const { title, description, thumbnail, date, category } = entry.data;
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
const sectionLabel = baseSlug === 'portfolio' ? 'Portfolio' : baseSlug === 'journal' ? 'Journal' : null;

// Icons logic (replacing SVG imports with inline or similar)
// For simplicity, using text or simple arrows.
---

<Layout title={title} description={description}>
  <article class={`post-content ${thumbnail ? '' : 'no-image'}`}>
    {sectionLabel && (
      <p class="post-content-section"><a href={`/${baseSlug}`}>{sectionLabel}</a></p>
    )}

    {categories.length > 0 && (
      <div class="filter-bar" role="group" aria-label={`Browse ${sectionLabel} by category`}>
        <a class="filter-pill" href={`/${baseSlug}`} data-category="all">All</a>
        {categories.map((cat) => (
          <a
            class={`filter-pill ${cat === category ? 'is-active' : ''}`}
            href={`/${baseSlug}?category=${encodeURIComponent(cat)}`}
            data-category={cat}
          >
            {cat}
          </a>
        ))}
      </div>
    )}

    <header class="post-content-header">
    <h1 class="post-content-title">
      {title}
      {formattedDate && <time class="post-content-date" datetime={new Date(date).toISOString()}>{formattedDate}</time>}
    </h1>
    </header>

    {description && (
      <p class="post-content-excerpt">{description}</p>
    )}

    {thumbnail && (
      <div class="post-content-image">
        <img src={thumbnail} class="kg-image" alt={title} />
      </div>
    )}

    <div class="post-content-body">
      <Content />
    </div>

    <div class="post-link">
      <div>
        {next && (
            <a style="display: flex; align-items: center; color: #131313; font-size: 2rem;" href={`/${baseSlug}/${next.slug}`}>
               <span>&larr; {next.data.title}</span>
            </a>
        )}
      </div>
      <div>
        {prev && (
            <a style="display: flex; align-items: center; color: #131313; font-size: 2rem;" href={`/${baseSlug}/${prev.slug}`}>
               <span>{prev.data.title} &rarr;</span>
            </a>
        )}
      </div>
    </div>

  </article>
</Layout>

<style>
  .post-content-section {
    text-align: center;
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 1.3rem;
  }
  .post-content-section a {
    color: color(var(--color-base) l(+40%));
    text-decoration: none;
  }
  .post-content-section a:hover {
    color: var(--color-base);
    text-decoration: underline;
  }
  .post-content-date {
    display: inline-block;
    margin-left: 1rem;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    font-weight: var(--font-normal);
    color: color(var(--color-base) l(+40%));
    vertical-align: middle;
  }
  @media (max-width: 700px) {
    .post-content-date {
      display: block;
      margin-left: 0;
      margin-top: 0.5rem;
    }
  }
</style>
