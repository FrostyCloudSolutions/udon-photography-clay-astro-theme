---
import Layout from '../layouts/Layout.astro';
import { PortableText } from 'astro-portabletext';

interface Props {
  title: string;
  description?: string | null;
  image?: string | null; // pre-built CDN URL
  body?: unknown | null; // portable text blocks
}

const { title, description, image, body } = Astro.props;
---

<Layout title={title} description={description ?? undefined}>
  <article class={`post-content ${image ? '' : 'no-image'}`}>
    <header class="post-content-header">
      <h1 class="post-content-title">{title}</h1>
    </header>

    {description && (
      <p class="post-content-excerpt">{description}</p>
    )}

    {image && (
      <div class="post-content-image">
        <img src={image} class="kg-image" alt={title} />
      </div>
    )}

    <div class="post-content-body">
      {body && <PortableText value={body} />}
    </div>

    <footer class="post-content-footer">
    </footer>
  </article>
</Layout>
